# syntax=docker/dockerfile:1.4

ARG PHP_VERSION=8.4
# Extensions compiled from GitHub release tarballs, not PECL — pecl.php.net
# 504s took down a CI build. Pinned versions; bump deliberately.
ARG PHPREDIS_VERSION=6.2.0
ARG XDEBUG_VERSION=3.4.2

# ===== BUILD STAGE =====
FROM php:${PHP_VERSION}-fpm-alpine AS builder

# Install system dependencies. build-base provides the compiler; autoconf is
# required by phpize (extensions build from source). libpq-dev headers build pdo_pgsql.
RUN apk add --no-cache \
    build-base \
    autoconf \
    libpq-dev \
    zip \
    unzip \
    git \
    curl \
    ca-certificates

# Install only the PHP extensions not already bundled in the base image.
# (pdo, ctype, mbstring, tokenizer, opcache and json ship with php:8.2-alpine.)
RUN docker-php-ext-install pdo_pgsql bcmath

# Redis extension from source (see ARG note up top)
ARG PHPREDIS_VERSION
RUN curl -fsSL https://github.com/phpredis/phpredis/archive/refs/tags/${PHPREDIS_VERSION}.tar.gz | tar xz -C /tmp \
    && cd /tmp/phpredis-${PHPREDIS_VERSION} \
    && phpize && ./configure && make -j$(nproc) install \
    && docker-php-ext-enable redis \
    && cd / && rm -rf /tmp/phpredis-${PHPREDIS_VERSION}

# Copy Composer
COPY --from=composer:latest /usr/bin/composer /usr/bin/composer

WORKDIR /app

# Copy only composer files for better layer caching
COPY backend/composer.json backend/composer.lock ./

# Install dependencies with optimizations
RUN composer install \
    --no-dev \
    --no-interaction \
    --prefer-dist \
    --optimize-autoloader \
    --no-scripts \
    --no-progress

# ===== DEVELOPMENT STAGE =====
FROM php:${PHP_VERSION}-fpm-alpine AS development

# $PHPIZE_DEPS provides the compiler toolchain needed to build PHP extensions;
# linux-headers is required to build xdebug (rtnetlink.h).
RUN apk add --no-cache \
    $PHPIZE_DEPS \
    linux-headers \
    libpq-dev \
    git \
    curl \
    ca-certificates \
    postgresql-client \
    redis

# Only pdo_pgsql and bcmath need building; the rest ship with the base image
RUN docker-php-ext-install pdo_pgsql bcmath

ARG PHPREDIS_VERSION
RUN curl -fsSL https://github.com/phpredis/phpredis/archive/refs/tags/${PHPREDIS_VERSION}.tar.gz | tar xz -C /tmp \
    && cd /tmp/phpredis-${PHPREDIS_VERSION} \
    && phpize && ./configure && make -j$(nproc) install \
    && docker-php-ext-enable redis \
    && cd / && rm -rf /tmp/phpredis-${PHPREDIS_VERSION}

ARG XDEBUG_VERSION
RUN curl -fsSL https://github.com/xdebug/xdebug/archive/refs/tags/${XDEBUG_VERSION}.tar.gz | tar xz -C /tmp \
    && cd /tmp/xdebug-${XDEBUG_VERSION} \
    && phpize && ./configure && make -j$(nproc) install \
    && docker-php-ext-enable xdebug \
    && cd / && rm -rf /tmp/xdebug-${XDEBUG_VERSION}

COPY --from=composer:latest /usr/bin/composer /usr/bin/composer

# PHP config for development
COPY docker/php/php.ini $PHP_INI_DIR/php.ini
COPY docker/php/opcache.ini $PHP_INI_DIR/conf.d/10-opcache.ini
COPY docker/php/xdebug.ini $PHP_INI_DIR/conf.d/20-xdebug.ini

WORKDIR /app

COPY backend/ .

# Install PHP dependencies including dev tools (pail, pint, phpunit) for the
# development image, and drop any stale cached package manifest copied from the
# host so Laravel rebuilds it against this vendor directory.
RUN composer install --no-interaction --prefer-dist --no-progress --no-scripts \
    && rm -rf bootstrap/cache/*.php

# Create necessary directories
RUN mkdir -p storage/logs storage/framework/{sessions,views,cache} bootstrap/cache && \
    chown -R www-data:www-data storage bootstrap/cache

# Copy entrypoint script
COPY docker/docker-entrypoint.sh /usr/local/bin/docker-entrypoint.sh
RUN chmod +x /usr/local/bin/docker-entrypoint.sh

EXPOSE 9000

ENTRYPOINT ["/usr/local/bin/docker-entrypoint.sh"]
CMD ["php-fpm"]

# ===== PRODUCTION STAGE =====
FROM php:${PHP_VERSION}-fpm-alpine AS production

# Runtime libraries only (libpq for pdo_pgsql)
RUN apk add --no-cache \
    libpq \
    ca-certificates \
    postgresql-client \
    redis

# Build extensions using throwaway build deps, then remove them to keep the image slim
ARG PHPREDIS_VERSION
RUN apk add --no-cache --virtual .build-deps $PHPIZE_DEPS libpq-dev curl \
    && docker-php-ext-install pdo_pgsql bcmath \
    && curl -fsSL https://github.com/phpredis/phpredis/archive/refs/tags/${PHPREDIS_VERSION}.tar.gz | tar xz -C /tmp \
    && cd /tmp/phpredis-${PHPREDIS_VERSION} \
    && phpize && ./configure && make -j$(nproc) install \
    && docker-php-ext-enable redis \
    && cd / && rm -rf /tmp/phpredis-${PHPREDIS_VERSION} \
    && apk del .build-deps

# Optimized PHP config for production
COPY docker/php/php.ini $PHP_INI_DIR/php.ini
COPY docker/php/opcache-prod.ini $PHP_INI_DIR/conf.d/10-opcache.ini

WORKDIR /app

COPY backend/ .
COPY --from=builder /app/vendor ./vendor
RUN rm -f bootstrap/cache/*.php

# Remove dev files
RUN rm -rf .git .github .gitignore tests phpunit.xml

RUN mkdir -p storage/logs storage/framework/{sessions,views,cache} bootstrap/cache && \
    chown -R www-data:www-data storage bootstrap/cache

COPY docker/docker-entrypoint.sh /usr/local/bin/docker-entrypoint.sh
RUN chmod +x /usr/local/bin/docker-entrypoint.sh

EXPOSE 9000

ENTRYPOINT ["/usr/local/bin/docker-entrypoint.sh"]
CMD ["php-fpm"]
